# Copy this file to .dev.vars for local development (.dev.vars is gitignored, never commit it).

# "minimal" (default, recommended) shows only a authentic/expired banner on /verify/[matricule].
# "full" also shows photo, matricule, function and validity to whoever scans the badge QR.
VERIFY_MODE=minimal

# Admin login (/login) — protects /admin and the /api/staff endpoints.
# In production these are set as Cloudflare secrets (wrangler secret put), never committed.
# ADMIN_USERS is a JSON array so multiple admins can log in; add more entries as needed.
ADMIN_USERS=[{"email":"admin@example.com","password":"change-me"}]
SESSION_SECRET=any-long-random-string
